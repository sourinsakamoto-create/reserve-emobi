DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Optional. Only needed when DATABASE_URL is a POOLED connection (e.g. Neon's
# "pooled connection" string, hostname usually contains "-pooler"). Set this
# to the same database's DIRECT (non-pooled) connection string — migrations
# need a direct connection because they take a session-level advisory lock
# that connection poolers don't support. If unset, migrations use
# DATABASE_URL directly, which is fine for a plain (non-pooled) Postgres.
DIRECT_URL=

# Required for staff login sessions. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Used once by `npm run db:seed` to bootstrap the first admin login.
# After the account exists, manage further staff accounts from /admin/staff.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# For uploading activity images from the admin screen. Set up a Vercel Blob
# store (Vercel dashboard → Storage → Create → Blob) and connect it to this
# project. On Vercel itself, no token is needed here — the store
# auto-authenticates via BLOB_STORE_ID + Vercel's own OIDC token. Only set
# BLOB_READ_WRITE_TOKEN if you want to test uploads from local `npm run dev`
# (copy it from the store's dashboard). Without either, admins can still
# paste an image URL directly instead of uploading a file.
BLOB_READ_WRITE_TOKEN=

# Email notifications (optional). If left blank, email sending is skipped
# and bookings still complete normally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=
