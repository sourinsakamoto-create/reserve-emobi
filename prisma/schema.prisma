// Tuk-tuk activity booking system schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A bookable tuk-tuk activity / tour plan (e.g. "街並みクルーズコース").
model Activity {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  highlights         String?        // short catchphrase shown under the name
  description        String
  imageUrl           String?        // hero image shown on the list/detail pages
  included           String?        // what's included (free text, one item per line)
  requirements       String?        // participation conditions: age range, license, etc.
  notices            String?        // cautions / notes (weather, schedule changes, etc.)
  durationMinutes    Int
  pricePerAdult      Int
  originalPriceAdult Int?           // pre-discount price per adult, for strikethrough display
  pricePerChild      Int            @default(0)
  defaultCapacity    Int            @default(4)
  isOnSale           Boolean        @default(true) // 販売設定: false にすると新規予約を停止
  deletedAt          DateTime?      // 削除日時(ソフトデリート)。過去の予約履歴を残すため物理削除は行わない場合がある
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  scheduleSlots      ScheduleSlot[]
}

// A concrete date + time slot with its own inventory (capacity),
// which is how per-slot stock / sales control (在庫管理・販売設定) is expressed.
model ScheduleSlot {
  id                 String              @id @default(cuid())
  activityId         String
  activity           Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date               String              // YYYY-MM-DD
  startTime          String              // HH:mm
  capacity           Int                 // total number of guests sellable in this slot
  isOpen             Boolean             @default(true) // 販売設定: 個別スロットの受付停止/再開
  deletedAt          DateTime?           // 削除日時(ソフトデリート)。予約履歴が紐づく枠は物理削除できないため使用
  bookings           Booking[]
  guideAvailabilities GuideAvailability[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([activityId, date, startTime])
  @@index([date])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum StaffRole {
  ADMIN
  GUIDE
}

// Staff login accounts for the /admin and /guide areas.
model StaffUser {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  name           String
  role           StaffRole           @default(ADMIN)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  availabilities GuideAvailability[]
  assignedBookings Booking[]         @relation("AssignedGuide")
}

// A guide marking themselves available for one specific departure (ScheduleSlot).
// Presence of a row = available for that exact date+time+activity; no row = not
// (yet) marked available. When multiple guides claim the same slot, the one
// with the earliest createdAt is treated as the primary/assigned guide.
model GuideAvailability {
  id             String       @id @default(cuid())
  guideId        String
  guide          StaffUser    @relation(fields: [guideId], references: [id], onDelete: Cascade)
  scheduleSlotId String
  scheduleSlot   ScheduleSlot @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([guideId, scheduleSlotId])
  @@index([scheduleSlotId])
}

// Singleton row (one record, id="singleton") for site-wide booking behavior toggles.
model BookingSettings {
  id                       String   @id @default("singleton")
  // When true, a departure can only be booked if at least one guide has
  // marked themselves available for it. Defaults to false so turning on
  // guide scheduling never silently blocks bookings until explicitly enabled.
  requireGuideAvailability Boolean  @default(false)
  updatedAt                DateTime @updatedAt
}

// Singleton row (one record, id="singleton") holding admin-editable
// customer email content. Null fields fall back to the built-in defaults
// in src/lib/emailTemplates.ts.
model EmailSettings {
  id                  String   @id @default("singleton")
  confirmationSubject String?
  confirmationBody    String?
  cancellationSubject String?
  cancellationBody    String?
  changeSubject       String?
  changeBody          String?
  updatedAt           DateTime @updatedAt
}

model Booking {
  id             String        @id @default(cuid())
  scheduleSlotId String
  scheduleSlot   ScheduleSlot  @relation(fields: [scheduleSlotId], references: [id], onDelete: Restrict)
  customerName   String
  customerKana   String?
  customerEmail  String
  customerPhone  String
  numAdults      Int           @default(1)
  numChildren    Int           @default(0)
  notes          String?
  status         BookingStatus @default(CONFIRMED)
  guideId        String?
  guide          StaffUser?    @relation("AssignedGuide", fields: [guideId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([scheduleSlotId])
  @@index([guideId])
}
